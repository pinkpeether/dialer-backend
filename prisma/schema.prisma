generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enumerations ─────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  AGENT
  SUPERVISOR
}

enum UserStatus {
  ONLINE
  OFFLINE
  READY
  BUSY
  WRAP_UP
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum ContactStatus {
  PENDING
  IN_QUEUE
  CALLING
  CONTACTED
  ANSWERED
  NO_ANSWER
  BUSY
  DONE
  FAILED
  VOICEMAIL
  CALLBACK
  WRONG_NUMBER
  DNC
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  NO_ANSWER
  FAILED
  COMPLETED
}

enum CallDisposition {
  ANSWERED
  NO_ANSWER
  VOICEMAIL
  CALLBACK
  WRONG_NUMBER
  DO_NOT_CALL
}

enum AgentSessionStatus {
  ACTIVE
  IDLE
  DISCONNECTED
}

// ── Models ───────────────────────────────────────────────────────────────────

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(AGENT)
  status       UserStatus @default(OFFLINE)
  agentCode    String?    @unique
  extension    String?
  phone        String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  // Relations
  calls        Call[]
  sessions     AgentSession[]
  callbacks    Callback[]
  dncEntries   DNCList[]
}

model Campaign {
  id           Int            @id @default(autoincrement())
  name         String
  description  String?
  status       CampaignStatus @default(DRAFT)
  callerId     String
  dialingRatio Int            @default(1)
  maxRetries   Int            @default(3)
  retryDelay   Int            @default(300)
  script       String?
  startTime    String?
  endTime      String?
  timezone     String         @default("UTC")
  mode         String         @default("PREVIEW")
  waitingReason String?
  lastSchedulerCheckAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // Relations
  contacts     Contact[]
  calls        Call[]
}

model Contact {
  id           Int           @id @default(autoincrement())
  name         String?
  phone        String
  email        String?
  company      String?
  status       ContactStatus @default(PENDING)
  callbackAt   DateTime?
  notes        String?
  retryCount   Int           @default(0)
  maxRetries   Int           @default(3)
  lastCalledAt DateTime?
  nextRetryAt  DateTime?
  lastDisposition String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  // Relations
  campaignId   Int?
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  calls        Call[]
  callbacks    Callback[]
}

model Call {
  id             Int              @id @default(autoincrement())
  contactId      Int
  campaignId     Int
  agentId        Int?
  providerCallId String?
  twilioCallSid  String?
  direction       String?
  remoteNumber   String?
  source         String?
  status         CallStatus       @default(INITIATED)
  disposition    CallDisposition?
  notes          String?
  duration       Int?
  recordingUrl   String?
  recordingSid   String?
  connectedAt    DateTime?
  startedAt      DateTime         @default(now())
  endedAt        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  // Relations
  contact        Contact          @relation(fields: [contactId], references: [id])
  campaign       Campaign         @relation(fields: [campaignId], references: [id])
  agent          User?            @relation(fields: [agentId], references: [id])
  callbacks      Callback[]
}

model Callback {
  id          Int            @id @default(autoincrement())
  contactId   Int?
  callId      Int?
  agentId     Int
  scheduledAt DateTime
  notes       String?
  status      String         @default("PENDING")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  // Relations
  contact     Contact?  @relation(fields: [contactId], references: [id])
  call        Call?     @relation(fields: [callId],    references: [id])
  agent       User      @relation(fields: [agentId],   references: [id])
}

model AgentSession {
  id             Int                @id @default(autoincrement())
  agentId        Int
  socketId       String
  status         AgentSessionStatus @default(IDLE)
  connectedAt    DateTime           @default(now())
  disconnectedAt DateTime?
  // Relations
  agent          User               @relation(fields: [agentId], references: [id])
}

model DNCList {
  id             Int      @id @default(autoincrement())
  phone          String   @unique
  reason         String?
  addedByUserId  Int?
  createdAt      DateTime @default(now())
  // Relations
  addedBy        User?    @relation(fields: [addedByUserId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?
  type      String
  title     String
  body      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}
