generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CUSTOMER_ADMIN
  MANAGER
  SUPERVISOR
  AGENT
}

enum UserStatus {
  ONLINE
  OFFLINE
  READY
  BUSY
  WRAP_UP
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum ContactStatus {
  PENDING
  IN_QUEUE
  CALLING
  CONTACTED
  ANSWERED
  NO_ANSWER
  BUSY
  DONE
  FAILED
  VOICEMAIL
  CALLBACK
  WRONG_NUMBER
  DNC
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  NO_ANSWER
  FAILED
  COMPLETED
}

enum CallDisposition {
  ANSWERED
  NO_ANSWER
  VOICEMAIL
  CALLBACK
  WRONG_NUMBER
  DO_NOT_CALL
}

enum AgentSessionStatus {
  ACTIVE
  IDLE
  DISCONNECTED
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  passwordHash    String
  role            UserRole         @default(AGENT)
  status          UserStatus       @default(OFFLINE)
  agentCode       String?          @unique
  extension       String?
  phone           String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  calls           Call[]
  sessions        AgentSession[]
  callbacks       Callback[]
  dncEntries      DNCList[]
  spoofingNumbers SpoofingNumber[]
  commercialMemberships CommercialAccountMembership[]
}

model Campaign {
  id                   Int              @id @default(autoincrement())
  name                 String
  description          String?
  status               CampaignStatus   @default(DRAFT)
  callerId             String
  dialingRatio         Int              @default(1)
  maxRetries           Int              @default(3)
  retryDelay           Int              @default(300)
  script               String?
  startTime            String?
  endTime              String?
  timezone             String           @default("UTC")
  mode                 String           @default("PROGRESSIVE")
  waitingReason        String?
  lastSchedulerCheckAt DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  contacts             Contact[]
  calls                Call[]
  spoofingNumbers      SpoofingNumber[]
}

model Contact {
  id              Int           @id @default(autoincrement())
  name            String?
  phone           String
  email           String?
  company         String?
  status          ContactStatus @default(PENDING)
  callbackAt      DateTime?
  notes           String?
  retryCount      Int           @default(0)
  maxRetries      Int           @default(3)
  lastCalledAt    DateTime?
  nextRetryAt     DateTime?
  lastDisposition String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  campaignId      Int?
  campaign        Campaign?     @relation(fields: [campaignId], references: [id])
  calls           Call[]
  callbacks       Callback[]
}

model Call {
  id             Int              @id @default(autoincrement())
  contactId      Int
  campaignId     Int
  agentId        Int?
  providerCallId String?
  direction      String?
  remoteNumber   String?
  source         String?
  status         CallStatus       @default(INITIATED)
  disposition    CallDisposition?
  notes          String?
  duration       Int?
  recordingUrl   String?
  recordingSid   String?
  connectedAt    DateTime?
  startedAt      DateTime         @default(now())
  endedAt        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  contact        Contact          @relation(fields: [contactId], references: [id])
  campaign       Campaign         @relation(fields: [campaignId], references: [id])
  agent          User?            @relation(fields: [agentId], references: [id])
  callbacks      Callback[]
  transcript     CallTranscript?
  insight        CallInsight?
}

model CallTranscript {
  id              Int       @id @default(autoincrement())
  callId          Int       @unique
  transcriptText  String    @db.Text
  provider        String
  model           String
  language        String?
  durationSeconds Int?
  status          String    @default("COMPLETED")
  errorMessage    String?   @db.Text
  generatedAt     DateTime  @default(now())
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  call            Call      @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([provider])
  @@index([generatedAt])
}

model CallInsight {
  id          Int       @id @default(autoincrement())
  callId      Int       @unique
  summary     String?   @db.Text
  sentiment   String?
  score       Float?
  intent      String?
  objections  Json?
  actionItems Json?
  provider    String?
  model       String?
  status      String    @default("PENDING")
  generatedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  call        Call      @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([sentiment])
  @@index([status])
  @@index([generatedAt])
}

model Callback {
  id          Int      @id @default(autoincrement())
  contactId   Int?
  callId      Int?
  agentId     Int
  scheduledAt DateTime
  notes       String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contact     Contact? @relation(fields: [contactId], references: [id])
  call        Call?    @relation(fields: [callId], references: [id])
  agent       User     @relation(fields: [agentId], references: [id])
}

model AgentSession {
  id             Int                @id @default(autoincrement())
  agentId        Int
  socketId       String
  status         AgentSessionStatus @default(IDLE)
  connectedAt    DateTime           @default(now())
  disconnectedAt DateTime?
  agent          User               @relation(fields: [agentId], references: [id])
}

model DNCList {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  reason        String?
  addedByUserId Int?
  createdAt     DateTime @default(now())
  addedBy       User?    @relation(fields: [addedByUserId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int?
  type      String
  title     String
  body      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}

model SpoofingNumber {
  id            Int       @id @default(autoincrement())
  userId        Int?      @map("user_id")
  campaignId    Int?      @map("campaign_id")
  displayNumber String    @map("display_number") @db.VarChar(20)
  displayName   String?   @map("display_name") @db.VarChar(100)
  provider      String    @default("generic") @db.VarChar(40)
  providerRef   String?   @map("provider_ref") @db.VarChar(120)
  isActive      Boolean   @default(true) @map("is_active")
  isVerified    Boolean   @default(false) @map("is_verified")
  scope         String    @default("all") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campaignId])
  @@index([isActive])
  @@index([isVerified])
  @@map("spoofing_numbers")
}

enum CommercialPlanCode {
  BASIC
  STANDARD
  PREMIUM
  ELITE
  ENTERPRISE
}

enum CommercialAddonCode {
  DYNAMIC_CALLER_ID
  SMS
  AI_TRANSCRIPTS
  AI_INSIGHTS
  RECORDINGS
  ADVANCED_ANALYTICS
  CRM_CONNECTORS
}

enum CommercialSubscriptionStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  EXPIRED
  TRIAL
}

enum CommercialFeatureStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum CommercialPaymentRequestStatus {
  PENDING_PAYMENT
  PAYMENT_SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum CommercialWalletTransactionType {
  MANUAL_TOPUP
  CALL_CHARGE
  SMS_CHARGE
  ADJUSTMENT
  REFUND
  BONUS_CREDIT
  HOLD
  CAPTURE
  RELEASE
}

enum CommercialWalletTransactionDirection {
  CREDIT
  DEBIT
  HOLD
  RELEASE
}

enum CommercialBillingAlertSeverity {
  INFO
  LOW_BALANCE
  CRITICAL_BALANCE
  HARD_STOP
}

model CommercialAccount {
  id                       Int                       @id @default(autoincrement())
  name                     String
  code                     String                    @unique
  status                   String                    @default("ACTIVE")
  email                    String?
  phone                    String?
  currency                 String                    @default("USD")
  lowBalanceThreshold      Decimal                   @default(10) @db.Decimal(12, 4)
  criticalBalanceThreshold Decimal                   @default(3) @db.Decimal(12, 4)
  hardStopEnabled          Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  wallet                   CommercialWallet?
  subscriptions            CommercialSubscription[]
  addons                   CommercialAccountAddon[]
  paymentRequests          CommercialPaymentRequest[]
  billingAlerts            CommercialBillingAlert[]
  memberships              CommercialAccountMembership[]

  @@index([status])
  @@index([createdAt])
}

model CommercialPlan {
  id              Int                        @id @default(autoincrement())
  code            CommercialPlanCode         @unique
  name            String
  monthlyFee      Decimal                    @default(0) @db.Decimal(12, 4)
  includedSeats   Int                        @default(0)
  description     String?
  features        Json?
  isActive        Boolean                    @default(true)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  subscriptions   CommercialSubscription[]
  paymentRequests CommercialPaymentRequest[]

  @@index([isActive])
}

model CommercialSubscription {
  id                 Int                          @id @default(autoincrement())
  accountId          Int
  planId             Int
  status             CommercialSubscriptionStatus @default(INACTIVE)
  startsAt           DateTime                     @default(now())
  endsAt             DateTime?
  monthlyFeeOverride Decimal?                     @db.Decimal(12, 4)
  billingCycle       String                       @default("MONTHLY")
  notes              String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  account            CommercialAccount            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plan               CommercialPlan               @relation(fields: [planId], references: [id])

  @@index([accountId])
  @@index([planId])
  @@index([status])
  @@index([startsAt])
}

model CommercialAddon {
  id            Int                      @id @default(autoincrement())
  code          CommercialAddonCode      @unique
  name          String
  monthlyFee    Decimal                  @default(0) @db.Decimal(12, 4)
  description   String?
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  accountAddons CommercialAccountAddon[]

  @@index([isActive])
}

model CommercialAccountAddon {
  id              Int                     @id @default(autoincrement())
  accountId       Int
  addonId         Int
  status          CommercialFeatureStatus @default(INACTIVE)
  priceOverride   Decimal?                @db.Decimal(12, 4)
  startsAt        DateTime?
  endsAt          DateTime?
  enabledByUserId Int?
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  account         CommercialAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  addon           CommercialAddon         @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([accountId, addonId])
  @@index([status])
  @@index([enabledByUserId])
}

model CommercialWallet {
  id               Int                           @id @default(autoincrement())
  accountId        Int                           @unique
  currency         String                        @default("USD")
  availableBalance Decimal                       @default(0) @db.Decimal(12, 4)
  heldBalance      Decimal                       @default(0) @db.Decimal(12, 4)
  creditLimit      Decimal                       @default(0) @db.Decimal(12, 4)
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  account          CommercialAccount             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions     CommercialWalletTransaction[]
}

model CommercialWalletTransaction {
  id               Int                                  @id @default(autoincrement())
  walletId         Int
  type             CommercialWalletTransactionType
  direction        CommercialWalletTransactionDirection
  amount           Decimal                              @db.Decimal(12, 4)
  balanceAfter     Decimal                              @db.Decimal(12, 4)
  referenceType    String?
  referenceId      String?
  description      String?
  metadata         Json?
  approvedByUserId Int?
  idempotencyKey   String?                              @unique
  createdAt        DateTime                             @default(now())
  wallet           CommercialWallet                     @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([direction])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model CommercialPaymentRequest {
  id               Int                             @id @default(autoincrement())
  accountId        Int
  requestedPlanId  Int?
  amount           Decimal                         @db.Decimal(12, 4)
  currency         String                          @default("USD")
  requestedAddons  Json?
  paymentMethod    String?
  paymentReference String?
  proofUrl         String?
  notes            String?
  status           CommercialPaymentRequestStatus  @default(PAYMENT_SUBMITTED)
  createdByUserId  Int?
  reviewedByUserId Int?
  reviewedAt       DateTime?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt
  account          CommercialAccount               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  requestedPlan    CommercialPlan?                 @relation(fields: [requestedPlanId], references: [id])

  @@index([accountId])
  @@index([requestedPlanId])
  @@index([status])
  @@index([createdAt])
}

model CommercialBillingAlert {
  id             Int                            @id @default(autoincrement())
  accountId      Int
  severity       CommercialBillingAlertSeverity
  title          String
  body           String?
  balanceAt      Decimal?                       @db.Decimal(12, 4)
  thresholdValue Decimal?                       @db.Decimal(12, 4)
  isRead         Boolean                        @default(false)
  readAt         DateTime?
  createdAt      DateTime                       @default(now())
  account        CommercialAccount              @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([severity])
  @@index([isRead])
  @@index([createdAt])
}

enum CommercialAccountRole {
  OWNER
  ADMIN
  BILLING
  SUPERVISOR
  AGENT
}

enum CommercialAccountMembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model CommercialAccountMembership {
  id                    Int                               @id @default(autoincrement())
  accountId             Int
  userId                Int
  accountRole           CommercialAccountRole             @default(AGENT)
  status                CommercialAccountMembershipStatus @default(ACTIVE)
  canManageUsers        Boolean                           @default(false)
  canManageBilling      Boolean                           @default(false)
  canManageCampaigns    Boolean                           @default(false)
  canViewReports        Boolean                           @default(true)
  canUseDynamicCallerId Boolean                           @default(false)
  createdByUserId       Int?
  notes                 String?                           @db.Text
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt
  account               CommercialAccount                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user                  User                              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([accountId])
  @@index([userId])
  @@index([accountRole])
  @@index([status])
  @@index([createdAt])
}

model AiCallLog {
  id                    Int       @id @default(autoincrement())
  provider              String    @default("retell")
  providerCallId        String    @unique
  lastEvent             String?
  callStatus            String?
  callType              String?
  direction             String?
  fromNumber            String?
  toNumber              String?
  agentId               String?
  agentName             String?
  durationMs            Int?
  disconnectionReason   String?
  transferDestination   String?
  transcriptText        String?   @db.Text
  transcriptLength      Int       @default(0)
  recordingUrl          String?   @db.Text
  hasRecordingUrl       Boolean   @default(false)
  callSummary           String?   @db.Text
  userSentiment         String?
  callSuccessful        Boolean?
  inVoicemail           Boolean?
  callAnalysis          Json?
  rawPayload            Json?
  lastWebhookAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([provider])
  @@index([lastEvent])
  @@index([callStatus])
  @@index([direction])
  @@index([toNumber])
  @@index([createdAt])
}
