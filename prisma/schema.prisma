generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  AGENT
  SUPERVISOR
}

enum UserStatus {
  ONLINE
  OFFLINE
  READY
  BUSY
  WRAP_UP
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum ContactStatus {
  PENDING
  IN_QUEUE
  CALLING
  CONTACTED
  ANSWERED
  NO_ANSWER
  BUSY
  DONE
  FAILED
  VOICEMAIL
  CALLBACK
  WRONG_NUMBER
  DNC
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  NO_ANSWER
  FAILED
  COMPLETED
}

enum CallDisposition {
  ANSWERED
  NO_ANSWER
  VOICEMAIL
  CALLBACK
  WRONG_NUMBER
  DO_NOT_CALL
}

enum AgentSessionStatus {
  ACTIVE
  IDLE
  DISCONNECTED
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  passwordHash    String
  role            UserRole         @default(AGENT)
  status          UserStatus       @default(OFFLINE)
  agentCode       String?          @unique
  extension       String?
  phone           String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  calls           Call[]
  sessions        AgentSession[]
  callbacks       Callback[]
  dncEntries      DNCList[]
  spoofingNumbers SpoofingNumber[]
}

model Campaign {
  id                   Int              @id @default(autoincrement())
  name                 String
  description          String?
  status               CampaignStatus   @default(DRAFT)
  callerId             String
  dialingRatio         Int              @default(1)
  maxRetries           Int              @default(3)
  retryDelay           Int              @default(300)
  script               String?
  startTime            String?
  endTime              String?
  timezone             String           @default("UTC")
  mode                 String           @default("PROGRESSIVE")
  waitingReason        String?
  lastSchedulerCheckAt DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  contacts             Contact[]
  calls                Call[]
  spoofingNumbers      SpoofingNumber[]
}

model Contact {
  id              Int           @id @default(autoincrement())
  name            String?
  phone           String
  email           String?
  company         String?
  status          ContactStatus @default(PENDING)
  callbackAt      DateTime?
  notes           String?
  retryCount      Int           @default(0)
  maxRetries      Int           @default(3)
  lastCalledAt    DateTime?
  nextRetryAt     DateTime?
  lastDisposition String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  campaignId      Int?
  campaign        Campaign?     @relation(fields: [campaignId], references: [id])
  calls           Call[]
  callbacks       Callback[]
}

model Call {
  id             Int              @id @default(autoincrement())
  contactId      Int
  campaignId     Int
  agentId        Int?
  providerCallId String?
  direction      String?
  remoteNumber   String?
  source         String?
  status         CallStatus       @default(INITIATED)
  disposition    CallDisposition?
  notes          String?
  duration       Int?
  recordingUrl   String?
  recordingSid   String?
  connectedAt    DateTime?
  startedAt      DateTime         @default(now())
  endedAt        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  contact        Contact          @relation(fields: [contactId], references: [id])
  campaign       Campaign         @relation(fields: [campaignId], references: [id])
  agent          User?            @relation(fields: [agentId], references: [id])
  callbacks      Callback[]
  transcript     CallTranscript?
  insight        CallInsight?
}

model CallTranscript {
  id              Int       @id @default(autoincrement())
  callId          Int       @unique
  transcriptText  String    @db.Text
  provider        String
  model           String
  language        String?
  durationSeconds Int?
  status          String    @default("COMPLETED")
  errorMessage    String?   @db.Text
  generatedAt     DateTime  @default(now())
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  call            Call      @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([provider])
  @@index([generatedAt])
}

model CallInsight {
  id          Int       @id @default(autoincrement())
  callId      Int       @unique
  summary     String?   @db.Text
  sentiment   String?
  score       Float?
  intent      String?
  objections  Json?
  actionItems Json?
  provider    String?
  model       String?
  status      String    @default("PENDING")
  generatedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  call        Call      @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([sentiment])
  @@index([status])
  @@index([generatedAt])
}

model Callback {
  id          Int      @id @default(autoincrement())
  contactId   Int?
  callId      Int?
  agentId     Int
  scheduledAt DateTime
  notes       String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contact     Contact? @relation(fields: [contactId], references: [id])
  call        Call?    @relation(fields: [callId], references: [id])
  agent       User     @relation(fields: [agentId], references: [id])
}

model AgentSession {
  id             Int                @id @default(autoincrement())
  agentId        Int
  socketId       String
  status         AgentSessionStatus @default(IDLE)
  connectedAt    DateTime           @default(now())
  disconnectedAt DateTime?
  agent          User               @relation(fields: [agentId], references: [id])
}

model DNCList {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  reason        String?
  addedByUserId Int?
  createdAt     DateTime @default(now())
  addedBy       User?    @relation(fields: [addedByUserId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int?
  type      String
  title     String
  body      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}

model SpoofingNumber {
  id            Int       @id @default(autoincrement())
  userId        Int?      @map("user_id")
  campaignId    Int?      @map("campaign_id")
  displayNumber String    @map("display_number") @db.VarChar(20)
  displayName   String?   @map("display_name") @db.VarChar(100)
  provider      String    @default("generic") @db.VarChar(40)
  providerRef   String?   @map("provider_ref") @db.VarChar(120)
  isActive      Boolean   @default(true) @map("is_active")
  isVerified    Boolean   @default(false) @map("is_verified")
  scope         String    @default("all") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campaignId])
  @@index([isActive])
  @@index([isVerified])
  @@map("spoofing_numbers")
}
