generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  ADMIN
  SUPERVISOR
  AGENT
}

enum AgentStatus {
  ONLINE
  READY
  BUSY
  WRAP_UP
  OFFLINE
}

enum ContactStatus {
  PENDING
  CALLING
  ANSWERED
  NO_ANSWER
  BUSY
  DONE
  DNC
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum CallStatus {
  INITIATED
  RINGING
  CONNECTED
  NO_ANSWER
  BUSY
  FAILED
  COMPLETED
  VOICEMAIL
}

enum DispositionType {
  INTERESTED
  NOT_INTERESTED
  CALLBACK
  WRONG_NUMBER
  VOICEMAIL_LEFT
  DNC_REQUEST
}

// ─── MODELS ──────────────────────────────────────────

model User {
  id        Int         @id @default(autoincrement())
  agentCode String      @unique // AGT-001
  name      String
  email     String      @unique
  password  String
  extension String? // 101
  phone     String? // Agent ka apna number
  role      Role        @default(AGENT)
  status    AgentStatus @default(OFFLINE)
  isActive  Boolean     @default(true)
  avatar    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  calls     Call[]
  sessions  Session[]

  @@map("users")
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

model Campaign {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  dialRatio   Int            @default(3)
  maxRetries  Int            @default(3)
  retryDelay  Int            @default(30) // minutes
  status      CampaignStatus @default(DRAFT)
  script      String? // Agent script text
  startTime   String? // "09:00"
  endTime     String? // "18:00"
  timezone    String         @default("Asia/Karachi")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  contacts    Contact[]
  calls       Call[]

  @@map("campaigns")
}

model Contact {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String
  email        String?
  company      String?
  notes        String?
  status       ContactStatus @default(PENDING)
  retryCount   Int           @default(0)
  lastCalledAt DateTime?
  campaignId   Int
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  calls        Call[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("contacts")
}

model Call {
  id              Int              @id @default(autoincrement())
  twilioCallSid   String?          @unique
  agentId         Int?
  agent           User?            @relation(fields: [agentId], references: [id])
  contactId       Int
  contact         Contact          @relation(fields: [contactId], references: [id])
  campaignId      Int
  campaign        Campaign         @relation(fields: [campaignId], references: [id])
  status          CallStatus       @default(INITIATED)
  duration        Int? // seconds
  recordingUrl    String? // Cloudflare R2 URL
  recordingSid    String? // Twilio Recording SID
  transcript      String? // Live transcript
  sentiment       String? // positive / neutral / negative
  sentimentScore  Float? // 0.0 - 1.0
  disposition     DispositionType?
  dispositionNote String?
  isWhispered     Boolean          @default(false)
  isBarged        Boolean          @default(false)
  startedAt       DateTime         @default(now())
  connectedAt     DateTime?
  endedAt         DateTime?

  @@map("calls")
}

model DNCList {
  id      Int      @id @default(autoincrement())
  phone   String   @unique
  reason  String?
  addedAt DateTime @default(now())

  @@map("dnc_list")
}

model SystemSettings {
  id                Int      @id @default(1)
  maxAgents         Int      @default(100)
  defaultDialRatio  Int      @default(3)
  recordCalls       Boolean  @default(true)
  transcribeCalls   Boolean  @default(false)
  sentimentAnalysis Boolean  @default(false)
  timezone          String   @default("Asia/Karachi")
  updatedAt         DateTime @updatedAt

  @@map("system_settings")
}
